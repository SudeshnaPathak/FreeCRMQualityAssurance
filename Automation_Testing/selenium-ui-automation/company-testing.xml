<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CrossBrowserSuite" parallel="tests" thread-count="3" verbose="2">
    <test name="ChromeSuite" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.freecrm.automation.runners.TestRunnerCompany"/>
        </classes>
    </test>

    <test name="FirefoxSuite" preserve-order="true">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.freecrm.automation.runners.TestRunnerCompany"/>
        </classes>
    </test>

    <test name="EdgeSuite" preserve-order="true">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.freecrm.automation.runners.TestRunnerCompany"/>
        </classes>
    </test>
</suite>
